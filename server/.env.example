# ============================================================
# Vocabulario 环境变量配置
# 复制此文件为 .env 并填入真实值
# ============================================================

# 阿里云百炼 API Key（必填）
# 获取地址: https://bailian.console.aliyun.com/
DASHSCOPE_API_KEY=sk-your-key-here

# ============================================================
# JWT 密钥（生产环境请务必修改为随机字符串！）
# ============================================================
JWT_SECRET=vocabulario-secret-key-dev
JWT_REFRESH_SECRET=vocabulario-refresh-secret-dev

# ============================================================
# ASR 后端选择
#   whisper = 本地 faster-whisper（默认，需要 Python + GPU）
#   doubao  = 火山引擎豆包 Seed ASR（云端 API，需配置下方 Key）
ASR_BACKEND=whisper

# 豆包 Seed ASR（火山引擎）— 切换到 doubao 后端时必填
# 获取地址: 火山引擎控制台 → 豆包语音 → API服务中心 → 服务接口认证信息
DOUBAO_STT_APP_KEY=
DOUBAO_STT_ACCESS_KEY=

# ============================================================
# 部署配置
# ============================================================

# 运行环境（生产部署时设为 production）
NODE_ENV=development

# CORS 允许的域名（生产环境设为你的域名，逗号分隔）
# 示例: https://vocabulario.example.com,https://www.example.com
CORS_ORIGIN=

# 服务端口（默认 3001，Render/云平台会自动注入 PORT）
PORT=3001
